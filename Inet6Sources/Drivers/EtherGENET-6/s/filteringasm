        GET     Hdr:ListOpts
        GET     Hdr:Macros
        GET     Hdr:System

        ; Filter data to a protocol handler

        EXPORT  filter_to_protocol

        AREA    filteringasm, PIC, CODE

        ; void filter_to_protocol(Dib *dib, struct mbuf *mbuf, filter_handler_t, void *pw)
        ;
        ; Loads the private word (arg3/pw) into r12/x12 then branches to the
        ; handler function (arg2).  Two-instruction veneer: no stack frame needed.
        ;
        ; 64-bit (AArch64, BUILD64=1):
        ;   Args arrive in x0-x3.  r12 does not exist — use x12 instead.
        ;   Indirect branch is BR not MOV pc.
        ;
        ; 32-bit (AArch32, default):
        ;   Args arrive in r0-r3.  MOV pc performs the indirect branch.
        ;
filter_to_protocol ROUT
        [ :DEF: RISCOS64
        MOV     x12, x3                 ; pw → x12 (module private word for callback)
        BR      x2                      ; tail-call to filter_handler_t
        |
        MOV     r12, r3                 ; pw → r12 (module private word for callback)
        MOV     pc, r2                  ; tail-call to filter_handler_t
        ]

        END
