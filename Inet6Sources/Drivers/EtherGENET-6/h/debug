#ifndef __debug_h
#define __debug_h

#ifdef INDEBUG

#define D_SWI 1
#define D_ALL 0xffffffff
#define D_THREAD 2
#define D_OTHER 4
#define D_IFMODULE 8
#define D_SOCKET 16
#define D_STACK 32
#define D_TASK 64
#define D_LOCK 128
#define D_IP6 256
#define D_CLOCK 512
#define D_YIELD 1024
#define D_FRAG 2048

#ifndef D_DEBUGLEVEL
#define D_DEBUGLEVEL (D_OTHER+D_SOCKET)
#endif

void debugf(unsigned int, char *,...);
void memdump(unsigned int, void *,int);
void mbufdump(unsigned int, void *);
void debuglog(unsigned int, char *);
void mbufchain(unsigned int, void *);
void dbpmem(int level,char* c,void* x, int bytes);
void prmbdata(int level, char* comment, void* m);

#else

#ifdef __CC_NORCROFT
/* Norcroft (C90) does not support variadic macros (...).
 * Use static no-op functions with the correct signatures instead.
 * C89 allows ... in function parameter lists, just not in #define. */
static void debugf(unsigned int level, char *fmt, ...) { (void)level; (void)fmt; }
static void memdump(unsigned int level, void *p, int n) { (void)level; (void)p; (void)n; }
static void mbufdump(unsigned int level, void *p) { (void)level; (void)p; }
static void mbufchain(unsigned int level, void *p) { (void)level; (void)p; }
static void debuglog(unsigned int level, char *s) { (void)level; (void)s; }
static void dbpmem(int level, char *c, void *x, int bytes) { (void)level; (void)c; (void)x; (void)bytes; }
static void prmbdata(int level, char *comment, void *m) { (void)level; (void)comment; (void)m; }
#else
#define debugf(...) do {} while (0)
#define memdump(...) do {} while (0)
#define mbufdump(...) do {} while (0)
#define mbufchain(...) do {} while (0)
#define debuglog(...) do {} while (0)
#define dbpmem(...) do {} while (0)
#define prmbdata(...) do {} while (0)
#endif

#endif

#endif
