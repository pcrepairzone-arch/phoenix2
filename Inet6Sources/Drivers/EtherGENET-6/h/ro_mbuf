typedef struct mbctl
{
  int     pw_content;   /* set to NULL on registration.  Used to locate Mbuf Manager workspace */
  int  mbcsize;        /* size of mbctl structure from client */
  unsigned int  mbcvers;        /* client version of mbuf manager spec */
  uint32_t      flags;          /* fixed-width: unsigned long is 4 bytes on 32-bit, 8 on 64-bit;
                                 * this struct is passed by pointer to the Mbuf Manager SWI so
                                 * layout must be identical in both builds */
  int        advminubs;      /* Advisory desired minimum underlying block size */
  int        advmaxubs;      /* Advisory desired maximum underlying block size */
  int        mincontig;      /* client required min ensure_contig value */
  unsigned int  unused1;         /* Must be set to zero on initialisation */ /* defined as unused1 for public */
  
  /* initialised by Mbuf Manager when session opened */
  int        minubs;         /* Minimum underlying block size */
  int        maxubs;         /* Maximum underlying block size */
  int        maxcontig;      /* Maximum contiguify block size */
  unsigned int  unused2;         /* Reserved for future use */ /* use internally for mbufglobals ptr? */

  /* functions exported by the manager module */
  /* main functions from sys/mbuf.h */
  struct mbuf * (*m_copym)(struct mbctl*, struct mbuf *, int, int, int);
  struct mbuf * (*m_free)(struct mbctl *, struct mbuf *);
  struct mbuf * (*m_get)(struct mbctl *, int, int);
