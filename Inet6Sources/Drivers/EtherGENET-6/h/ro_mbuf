  void  (*m_removehdr)(struct mbctl *, struct mbuf *);
  void  (*m_resethdr)(struct mbctl *, struct mbuf *);
  void  (*m_calchdrlen)(struct mbuf *);
  int   (*m_defrag)(struct mbctl *, struct mbuf *, int);
  struct mbuf * (*m_prepend)(struct mbctl *, struct mbuf *, int, int);
  struct mbuf * (*m_pulldown)(struct mbctl *, struct mbuf *, int, int, int *);
  struct mbuf * (*m_pullup)(struct mbctl *, struct mbuf *, int);
  struct mbuf * (*m_split)(struct mbctl *, struct mbuf *, int, int);
  struct mbuf * (*m_makespace)(struct mbctl *, struct mbuf *, int, int, int *);
  struct mbuf * (*m_getptr)(struct mbuf *, int, int *);
  int   (*m_leadingspace)(struct mbuf *);
  int   (*m_trailingspace)(struct mbuf *);
  void  (*m_align)(struct mbuf *, int);
  struct mbuf * (*m_clget)(struct mbctl *, struct mbuf *, int, unsigned int);
  void  (*m_extref)(struct mbctl *, struct mbuf *, struct mbuf *);
  void  (*m_adj)(struct mbuf *, int);
  int   (*m_copyback)(struct mbctl *, struct mbuf *, int, int, const void *, int);
  struct mbuf * (*m_freem)(struct mbctl *, struct mbuf *);
  void  (*m_purge)(struct mbctl *, struct mbuf *);
