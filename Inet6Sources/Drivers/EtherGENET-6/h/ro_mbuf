/* from sys/mbuf.h - couldn't be set up there */
static inline struct mbuf *
m_freemp(struct mbuf **mp)
{
        struct mbuf *m = *mp;

        *mp = 0;
        return m_freem(m);
}

/* from sys/mbuf.c */
/*
 * Apply function f to the data in an mbuf chain starting "off" bytes from the
 * beginning, continuing for "len" bytes.
 */
static inline int
m_apply(struct mbuf *m, int off, int len,
    int (*f)(void *, void *, unsigned int), void * fstate)
{
        int rval;       
        unsigned int count;
        
        if (len < 0 || off < 0) return 0;
        while (off > 0) {
                if (m == 0) return 0;
                if (off < m->m_len)
                        break;
                off -= m->m_len;
                m = m->m_next;
        }
        while (len > 0) {
                if (m == 0) return 0;
                count = m->m_len - off < len ? m->m_len - off : len;
                rval = f(fstate, mtod(m, char *) + off, count);
                if (rval) return (rval);
                len -= count;
                off = 0;
                m = m->m_next;
        }
        return (0);
}


