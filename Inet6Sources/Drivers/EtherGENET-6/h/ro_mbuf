// you shouldn't be playing with this one directly
struct pool {
  int pw_content;  // private word contents
  void *mbufglobals;  // pointer to mbufmanager workspace
  char *pool_owner_id;
  int pool_array_offset;
  char *pool_data_addr; // start of pool in memory
  char *pool_data_end;  // end of pool in memory
  char *pool_name;
  short pool_ipl;
  short pool_flags;
  char *pool_lowat;
  char *pool_hiwat;
  unsigned int pr_hardlimit; //pool_limit;
  int pr_size; //pool_blocksize;
  void *pool_freechain_first;
  void *pool_inusechain_first;
  unsigned int pr_nout; // pool_inuse_count;
  unsigned int pr_nfree; // pool free count (blocks on the free chain, not free space)
  char *pool_memtop;    // top of the allocated blocks in pool
  char *pool_last_pagedaddr; // last spot actually paged in
  int callback_wanted; // are we wanting a callback for memory moves?
};

