#ifndef __entrypoints_h
#define __entrypoints_h

#include <stdint.h>

/* list of entry points for internet stack to directly call
   our driver.

   ep_flags states which points are supported (bitmask)
*/

#define EPFLAG_TXPACKET 1

typedef struct {
  int      ep_flags;
  uintptr_t r12;           /* module private word — must be pointer-sized.
                            * On AArch32 this is 32 bits; on AArch64 it is
                            * 64 bits.  Never use plain int here: a 64-bit
                            * workspace pointer would be silently truncated. */
  void    *tx_packet_veneer;
} if_entrypoint;

#endif
