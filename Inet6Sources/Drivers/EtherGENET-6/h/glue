                                for (i = 0; i < ETHER_ADDR_LEN; i++) printf("%02X ", k ## [i]); \
                           } while (0);

/* Interface to GENET backend driver */
struct ifnet
{
	void    *if_softc;

	char     if_xname[4];     /* Unused by RISC OS */
	uint32_t if_flags;        /* Unused by RISC OS */
	uint32_t if_capabilities; /* Unused by RISC OS */
	uint32_t if_capenable;    /* Unused by RISC OS */

	/* Link level structure just used as a pointer to EUI48 */
	struct sockaddr_dl *if_sadl;

	int (*if_init)        /* Initialise */
	      (struct ifnet *);
	int (*if_ioctl)       /* I/O control */
	      (struct ifnet *, u_long, void *);
	void (*if_watchdog)   /* Watchdog */
	      (struct ifnet *);
	void (*if_start)      /* Start interface */
	      (struct ifnet *);
	void (*if_stop)       /* Stop interface */
	      (struct ifnet *, int);

	/* Cache of latest PHY status */
	uint16_t phy_auxsts;

	/* Broadcom BCM54213 vendor specific */
#define PHY_ID_BCM54213     0x84A0600D

#define MII_BCM_AUXSTS      0x19
#define AUXSTS_ACOMP        0x8000
#define AUXSTS_AN_ACK       0x4000
#define AUXSTS_AN_ACK_D     0x2000
#define AUXSTS_AN_NPW       0x1000
#define AUXSTS_AN_RES       0x0700
#define AUXSTS_LINK         0x0004
#define AUXSTS_RES_1000F    0x0700
#define AUXSTS_RES_1000H    0x0600
#define AUXSTS_RES_100F     0x0500
#define AUXSTS_RES_100T4    0x0400
#define AUXSTS_RES_100H     0x0300
#define AUXSTS_RES_10F      0x0200
#define AUXSTS_RES_10H      0x0100
#define AUXSTS_RES_IS_FULL(r) (((r) == AUXSTS_RES_1000F) || ((r) == AUXSTS_RES_100F) || ((r) == AUXSTS_RES_10F))
#define AUXSTS_RES_IS_1000(r) (((r) == AUXSTS_RES_1000F) || ((r) == AUXSTS_RES_1000H))
#define AUXSTS_RES_IS_100(r)  (((r) == AUXSTS_RES_100F) || ((r) == AUXSTS_RES_100T4) || ((r) == AUXSTS_RES_100H))
#define AUXSTS_RES_IS_10(r)   (((r) == AUXSTS_RES_10F) || ((r) == AUXSTS_RES_10H))

#define MII_BCM_SHADOW      0x1C
#define SHADOW_SELECT_SHIFT 10
#define SHADOW_WRITE_EN     (1<<15)
#define SHADOW_VALUE_MASK   0x3FF
#define SHADOW_REG_LED_CTRL 9  /* LED control */
#define SHADOW_REG_LEDS1    13 /* Even more LED control */

	/* Micrel KSZ9131 vendor specific */
#define PHY_ID_KSZ9131      0x16400022

#define MII_KSZ_LEDSELECT   0x16

#define MII_KSZ_LEDBEHAVE   0x17
#define LEDBEHAVE_STRETCH1  (1<<5)
#define LEDBEHAVE_STRETCH2  (1<<6)
#define LEDBEHAVE_SPLIT1    (1<<0)
#define LEDBEHAVE_SPLIT2    (1<<1)

#define MII_KSZ_MDIODRV     0x19
#define MDIODRV_PUSHPULL    (1<<1)

#define MII_KSZ_LEDM9031    0x1A
#define LEDM9031_NORMAL     (1<<14)

#define MII_KSZ_CONTROL     0x1F
#define CONTROL_1000T       64
#define CONTROL_100TX       32
#define CONTROL_10BT        16
#define CONTROL_DUPLEX      8

	/* Watchdog */
	uint32_t if_timer;

	/* Handover mbuf chain */
	struct mbuf          *if_snd;
};

/* Just enough ethercom to make it compile */
struct ethercom
{
	struct ifnet ec_if;
	struct mii_data *ec_mii;
	uint32_t ec_capabilities;
};

