#include "Global/Services.h"
#include "../VersionNum"

title-string:           EtherGenet

help-string:            EtherGENET Module_MajorVersion_CMHG Module_MinorVersion_CMHG Pi400

date-string:            Module_Date_CMHG

international-help-file:"Resources:$.Resources.EtherGENET.Messages"

initialisation-code:    etherge_init

finalisation-code:      etherge_final

service-call-handler:   etherge_services Service_EnumerateNetworkDrivers,
                                         Service_DCIProtocolStatus,
                                         Service_MbufManagerStatus,
                                         Service_ResourceFSStarting,
                                         Service_PreReset,
					 0x41200
// 0x41200 = Service_EnumerateNWDrivers6

swi-chunk-base-number:  0x59F00

swi-handler-code:       etherge_swis

swi-decoding-table:     EtherGE,
                        DCIVersion Inquire GetNetworkMTU SetNetworkMTU,
                        Transmit Filter Stats MulticastRequest EntryPoints

generic-veneers:        etherge_interrupt,
                        etherge_driver_linked,
                        etherge_heartbeat,
                        dci_tx_veneer/dci_tx_handler

command-keyword-table:  etherge_commands
        EGEInfo(min-args:0, max-args:1,
                international:,
                help-text:      "HEGEI",
                invalid-syntax: "SEGEI"),

        EGETest(min-args:0, max-args:1,
                international:,
                help-text:      "HEGET",
                invalid-syntax: "SEGET"),

        EGELink(min-args:2, max-args:4,
                configure:,
                international:,
                help-text:      "HEGEL",
                invalid-syntax: "SEGEL"),

        EGEAdvertise(min-args:2, max-args:8,
                configure:,
                international:,
                help-text:      "HEGEA",
                invalid-syntax: "SEGEA"),

        EGEFlowControl(min-args:2, max-args:2,
                configure:,
                international:,
                help-text:      "HEGEFC",
                invalid-syntax: "SEGEFC")
