#include <string.h>

#include "kernel.h"
#include "swis.h"

#include "mbuf6.h"

#include "ro_mbuf.h"

dci4_mbctl6 mbctl6;

#ifndef Socket_MBuf
#define Socket_MBuf 0x41228
#endif

_kernel_oserror *mbuf_register6(void **mbctl_inuse, size_t minubs, size_t maxubs, size_t mincontig)
{
  memset(&mbctl6,0,sizeof(dci4_mbctl6));
  mbctl6.mbcsize = sizeof(mbctl6);
  mbctl6.mbcvers = MBUF_MANAGER_VERSION;
  mbctl6.flags   = 0;
  mbctl6.advminubs = minubs;
  mbctl6.advmaxubs = maxubs;
  mbctl6.mincontig = mincontig;

  _kernel_oserror* e = _swix(Socket_MBuf, _INR(0,2), 0x100, &mbctl6, "EtherUSB");
  if (!e) {
    *mbctl_inuse = &mbctl6;
  }

  return e;
}

_kernel_oserror *mbuf_deregister6(void **inuse)
{
  _swix(Socket_MBuf,_INR(0,1),0x101,*inuse);
  return NULL;
}
