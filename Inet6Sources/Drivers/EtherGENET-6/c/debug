void debugf(unsigned int level, char *format,...)
{
  if ((level & D_DEBUGLEVEL)==0) return;

  int len,i;
  va_list ap;
  va_start(ap,format);
  len=vsnprintf(NULL,0,format,ap);

  va_start(ap,format);
  char buf[len+1];
  vsnprintf(buf,len+1,format,ap);
  va_end(ap);

#ifdef DADEBUG
  if (DADWriteC==0) {
    if (_swix(0x531c0,_OUT(0),&DADWriteC)) return;
  }

  for (i=0;_expand[i].id;i++) {
    if (_expand[i].id & level) debug_da_string(_expand[i].leveltext,strlen(_expand[i].leveltext));
  }

  debug_da_string(buf,len);
#else
  put_text(level, buf);
#endif
}

void debuglog(unsigned int level, char *str)
{
  if ((level & D_DEBUGLEVEL)==0) return;

#ifndef DADEBUG
  put_text(level, str);
#else
  int i;
  for (i=0;_expand[i].id;i++) {
    if (_expand[i].id & level) debug_da_string(_expand[i].leveltext,strlen(_expand[i].leveltext));
  }
  debug_da_string(str,strlen(str));

#endif
}

void dbpmem(int level, char* c, void* x, int bytes)
{
  char buf[4*16];
  unsigned char* p=(unsigned char*)x;
  int i;
   debugf(level,"%s\n",c);
  for (i=0;i<bytes;)
  {
    buf[0]=0;
    int j=i+16;
    for(;(i<bytes)&&(i<j);i++)
    {
      sprintf(buf+strlen(buf),"%02x ",*p++);
    }
   debugf(level," %s\n",buf);

  }
}

// fudge for mbuf definition to avoid much other stuff from the h file
struct mmbuf {
        struct    mmbuf *m_next;     /* next buffer in chain */
        struct    mmbuf *m_nextpkt;  /* next chain in queue/record */
        char      *m_data;          /* location of data */
        int       m_len;            /* amount of data in this mbuf */
        short       m_type;           /* type of data in this mbuf */
        short       m_flags;          /* flags; see below */
        int       mmanager;         /* mbuf manager use - internal flags */
};


void prmbdata(int level, char* comment, void* my)
{
 struct mmbuf * m = (struct mmbuf*)my;
 debugf(level,"%s\n",comment);
 while(m)
 {
   dbpmem(level,"",m->m_data,m->m_len);
   m=m->m_next;
 }

}

