static int SCRBASE;
static int ROWSTRIDE;

void plot_char(unsigned int level, char c,int start_offset)
{
  int row,bit;
  int *scr;
  int index,colour;

  __asm {
    CLZ index,level;
  }

  colour=_debug_colour[index];

  scr=(int *)start_offset;

  for (row=0;row<8;row++) {
    for (bit=7;bit>=0;bit--) {

      scr=(int *)(start_offset+row*ROWSTRIDE+4*(7-bit));

      *scr=(chardefs[c-32][row] & (1<<bit)) ? colour : 0;
    }
  }
}

void put_text(unsigned int level, char *string)
{
  int i;

  if (_text_row==NULL) {
/*    if (_swix(0x4a58a,_OUT(0),&_text_row)) */ _text_row=&local_textrow;
  }

  if (SCRBASE==NULL) {
    int vdu[3];
    vdu[0]=149;
    vdu[1]=11;
    vdu[2]=-1;
    if (!_swix(OS_ReadVduVariables,_INR(0,1),vdu,vdu)) {
      SCRBASE=vdu[0];
      ROWSTRIDE=(1+vdu[1])*4;
    } else return;
  }

  for (i=0;string[i];i++) {
    if (string[i]>31) plot_char(level, string[i],SCRBASE+i*32+*_text_row*ROWSTRIDE*8); else plot_char(level,' ',SCRBASE+i*32+*_text_row*ROWSTRIDE*8);
  }

  *_text_row=((*_text_row)+1) % 180;
  for (i=0;i<10;i++) {
    plot_char(0, '*',SCRBASE+*_text_row*ROWSTRIDE*8+32*i);
  }
  plot_char(0, ' ',SCRBASE+*_text_row*ROWSTRIDE*8+32+320);
}
