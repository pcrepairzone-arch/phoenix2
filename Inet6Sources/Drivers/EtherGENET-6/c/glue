/*
 * Period poll of PHY
 */
void mii_tick(struct mii_data *mii)
{
	uint16_t reg, ctrl;
	device_t self = (device_t)mii->mii_ifp->if_softc;
	struct ifnet *ifp = mii->mii_ifp;
	struct genet_softc *sc = (struct genet_softc *)mii->mii_ifp->if_softc;
	uint16_t old_auxsts = ifp->phy_auxsts;

	ifp->phy_auxsts = 0; /* In case of read error */
	switch (mii->mii_instance)
	{
		case PHY_ID_BCM54213:
			if (mii->mii_readreg(self, sc->sc_phy_id, MII_BCM_AUXSTS, &reg) == 0)
			{
				ifp->phy_auxsts = reg;
			}
			break;

		case PHY_ID_KSZ9131:
			if ((mii->mii_readreg(self, sc->sc_phy_id, MII_BMSR, &reg) == 0) &&
			    (mii->mii_readreg(self, sc->sc_phy_id, MII_KSZ_CONTROL, &ctrl) == 0))
			{
				uint16_t mapped = 0;
				bool full = (ctrl & CONTROL_DUPLEX) != 0;

				/* Map these to Broadcom AUXSTS layout */
				if (reg & BMSR_LINK)      mapped |= AUXSTS_LINK;
				if (ctrl & CONTROL_1000T) mapped |= AUXSTS_RES_1000F;
				if (ctrl & CONTROL_100TX) mapped |= full ? AUXSTS_RES_100F
				                                         : AUXSTS_RES_100H;
				if (ctrl & CONTROL_10BT)  mapped |= full ? AUXSTS_RES_10F
				                                         : AUXSTS_RES_10H;
				ifp->phy_auxsts = mapped;
			}
			break;
	}
	if (ifp->phy_auxsts != old_auxsts)
	{
		uint16_t res = ifp->phy_auxsts & AUXSTS_AN_RES;

		/* Formulate the active state and notify the driver so
		 * it can make any MAC level changes.
		 */
		mii->mii_media_active = AUXSTS_RES_IS_1000(res) ? IFM_1000_T :
		                        AUXSTS_RES_IS_100(res) ? IFM_100_TX :
		                        IFM_10_T;
		mii->mii_statchg(ifp);
	}
}

