/*
 * Register the PHY with the PHY handler
 */
void mii_attach(device_t parent, struct mii_data *mii, int capmask,
                int phyloc, int offloc, int flags)
{
	device_t self = (device_t)mii->mii_ifp->if_softc;
	int8_t   address;
	uint32_t id;

	/* Scan for all possible PHYs */
	for (address = MII_NPHY - 1; address >= 0; address--)
	{
		struct genet_softc *sc = (struct genet_softc *)mii->mii_ifp->if_softc;
		uint16_t *half = (uint16_t *)&id;
		uint16_t reg;

		if ((mii->mii_readreg(self, address, MII_PHYIDR1, &half[0]) == 0) &&
		    (mii->mii_readreg(self, address, MII_PHYIDR2, &half[1]) == 0) &&
		    (id != 0xFFFFFFFFuL))
		{
			DPRINTF(("PHY addr %u, id=%08X\n", address, id));
			sc->sc_phy_id = address;

			/* Knock out the revision from the id and stash for later discrimination */
			mii->mii_instance = id & ~0xF0000;
			switch (mii->mii_instance)
			{
				case PHY_ID_BCM54213:
				default:
					sc->sc_phy_mode = GENET_PHY_MODE_RGMII;
					break;

				case PHY_ID_KSZ9131:
					sc->sc_phy_mode = GENET_PHY_MODE_RGMII_RXID;

					/* Defend against weak pullup resistors by using push pull MDIO */
					mii->mii_readreg(self, address, MII_KSZ_MDIODRV, &reg);
					reg = reg | MDIODRV_PUSHPULL;
					mii->mii_writereg(self, address, MII_KSZ_MDIODRV, reg);
					break;
			}
			break;
		}
		sc->sc_phy_id = -1;
	}

	LIST_INIT(&mii->mii_phys);
	if (address >= 0)
	{
		static struct mii_softc sc_mii;

		/* There's only ever one PHY, but we need to pass a LIST_EMPTY check */
		LIST_INSERT_HEAD(&mii->mii_phys, &sc_mii, mii_list);
	}

	UNUSED(parent);
	UNUSED(capmask);
	UNUSED(phyloc);
	UNUSED(offloc);
	UNUSED(flags);
}

/*
 * Media change request, write the PHY settings again
 */
int mii_mediachg(struct mii_data *mii)
{
	size_t   i;
	uint16_t reg;
	uint16_t flags;
	device_t self = (device_t)mii->mii_ifp->if_softc;
	struct genet_softc *sc = (struct genet_softc *)mii->mii_ifp->if_softc;

	for (i = 0; i < NIC_MAX_CONTROLLERS; i++)
	{
		DPRINTF(("Configuring PHY on MAC %d from CMOS 0x%X\n", i, nic[i].flags));

		/* Map from CMOS flags into some PHY setup commands */
		flags = nic[i].flags;

		if (flags & NIC_FLAG_LINKAUTO)
		{
			DPRINTF(("Setting PHY for autonegotiate\n"));

			reg = ANAR_CSMA;
			if (flags & NIC_FLAG_FLOW_GEN) reg |= ANAR_PAUSE_SYM;
			if (flags & NIC_FLAG_FLOW_RESP) reg |= ANAR_PAUSE_ASYM;
			if (flags & NIC_FLAG_AD10_FULL) reg |= ANAR_10_FD;
			if (flags & NIC_FLAG_AD10_HALF) reg |= ANAR_10;
			if (flags & NIC_FLAG_AD100_FULL) reg |= ANAR_TX_FD;
			if (flags & NIC_FLAG_AD100_HALF) reg |= ANAR_TX;
			mii->mii_writereg(self, sc->sc_phy_id, MII_ANAR, reg);

			reg = 0;
			if (flags & NIC_FLAG_AD1000) reg |= GTCR_ADV_1000TFDX;
			mii->mii_writereg(self, sc->sc_phy_id, MII_GTCR, reg);

			reg = BMCR_AUTOEN | BMCR_STARTNEG;
			mii->mii_writereg(self, sc->sc_phy_id, MII_BMCR, reg);
		}
		else
		{
			DPRINTF(("Setting PHY to forced speed & duplex\n"));

			reg = 0;
			if (flags & NIC_FLAG_LINK100) reg |= BMCR_SPEED0;
			if (flags & NIC_FLAG_LINKFULL) reg |= BMCR_FDX;
			mii->mii_writereg(self, sc->sc_phy_id, MII_BMCR, reg);
		}

		switch (mii->mii_instance)
		{
			case PHY_ID_BCM54213:
				/* Everyone loves flashy lights, set LED1[7:4] and LED2[3:0] */
				mii->mii_writereg(self, sc->sc_phy_id, MII_BCM_SHADOW, SHADOW_REG_LED_CTRL << SHADOW_SELECT_SHIFT);
				mii->mii_readreg(self, sc->sc_phy_id, MII_BCM_SHADOW, &reg);
				reg = 16 /* Enable activity/link trigger */ | (reg & SHADOW_VALUE_MASK) |
				      (SHADOW_REG_LED_CTRL << SHADOW_SELECT_SHIFT) | SHADOW_WRITE_EN;
				mii->mii_writereg(self, sc->sc_phy_id, MII_BCM_SHADOW, reg);
				reg = (3 << 0) /* Green = link (+blinks for activity) */ |
				      (0 << 4) /* Amber = on for 1000/10 speed, off for 100 */ |
				      (SHADOW_REG_LEDS1 << SHADOW_SELECT_SHIFT) | SHADOW_WRITE_EN;
				mii->mii_writereg(self, sc->sc_phy_id, MII_BCM_SHADOW, reg);
				break;

			case PHY_ID_KSZ9131:
				/* Use enhanced mode to dodge errata DS80000863B */
				mii->mii_readreg(self, sc->sc_phy_id, MII_KSZ_LEDM9031, &reg);
				reg = reg & ~LEDM9031_NORMAL;
				mii->mii_writereg(self, sc->sc_phy_id, MII_KSZ_LEDM9031, reg);
				/* Everyone loves flashy lights, set LED1[3:0] and LED2[7:4] */
				mii->mii_readreg(self, sc->sc_phy_id, MII_KSZ_LEDBEHAVE, &reg);
				reg = (reg & ~LEDBEHAVE_SPLIT1) | LEDBEHAVE_SPLIT2;
				mii->mii_writereg(self, sc->sc_phy_id, MII_KSZ_LEDBEHAVE, reg);
				reg = (0 << 0) /* Green = link (+blinks for activity) */ |
				      (5 << 4) /* Amber = on for 1000/10 speed, off for 100 */;
				mii->mii_writereg(self, sc->sc_phy_id, MII_KSZ_LEDSELECT, reg);
				break;
		}
	}

	return 0;
}

