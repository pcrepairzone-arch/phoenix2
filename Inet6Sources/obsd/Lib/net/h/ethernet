/*
 * net/ethernet.h — RISC OS stub providing standard Ethernet constants.
 * Sourced from obsd if_ether.h (OpenBSD).
 */
#ifndef _NET_ETHERNET_H_
#define _NET_ETHERNET_H_

#define ETHER_ADDR_LEN          6       /* Ethernet address length */
#define ETHER_TYPE_LEN          2       /* Ethernet type field length */
#define ETHER_CRC_LEN           4       /* Ethernet CRC length */
#define ETHER_HDR_LEN           ((ETHER_ADDR_LEN * 2) + ETHER_TYPE_LEN)
#define ETHER_MIN_LEN           64      /* Minimum frame length, CRC included */
#define ETHER_MAX_LEN           1518    /* Maximum frame length, CRC included */
#define ETHER_MAX_DIX_LEN       1536    /* Maximum DIX frame length */
#define ETHER_VLAN_ENCAP_LEN    4       /* 802.1Q VLAN encapsulation length */

/*
 * Mbuf adjust factor to force 32-bit alignment of IP header.
 * Drivers do m_adj(m, ETHER_ALIGN) when setting up a receive buffer.
 */
#define ETHER_ALIGN             2       /* driver adjust for IP hdr alignment */

#define ETHER_MAX_HARDMTU_LEN   65435

/* Ethernet multicast address test */
#define ETHER_IS_MULTICAST(addr)  (*(addr) & 0x01)

#endif /* _NET_ETHERNET_H_ */
